# Copy this file to `.env` and fill in the values. `.env` is gitignored.
#
# Two ways to make these variables visible to your tools (Claude Code MCP,
# scripts/spike-epidemic.ts, etc.):
#   1) Load them in your shell:        set -a; source .env; set +a
#   2) Pass them to the Node/tsx run:  pnpm exec tsx --env-file=.env scripts/spike-epidemic.ts
#
# Claude Code interpolates ${VAR} inside `.mcp.json` from the environment of the
# process that launches `claude`, so make sure the variable is exported before
# starting the session.

# Epidemic Sound — personal API key (Bearer JWT).
# Generate it at: https://www.epidemicsound.com/account/api-keys
# It expires after 30 days: rotate it and paste the new value here.
EPIDEMIC_SOUND_API_KEY=your_epidemic_sound_api_key_here
